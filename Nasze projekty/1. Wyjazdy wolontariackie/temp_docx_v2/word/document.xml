an" w:eastAsia="Times New Roman" w:hAnsi="Times New Roman" w:cs="Times New Roman"/><w:kern w:val="0"/><w:lang w:eastAsia="pl-PL"/><w14:ligatures w14:val="none"/></w:rPr></w:pPr><w:r w:rsidRPr="00A17E39"><w:rPr><w:rFonts w:ascii="Times New Roman" w:eastAsia="Times New Roman" w:hAnsi="Times New Roman" w:cs="Times New Roman"/><w:kern w:val="0"/><w:lang w:eastAsia="pl-PL"/><w14:ligatures w14:val="none"/></w:rPr><w:t>Dla studentów medycyny, pielęgniarstwa i położnictwa.</w:t></w:r></w:p><w:p w14:paraId="61E5E131" w14:textId="77777777" w:rsidR="00A17E39" w:rsidRPr="00A17E39" w:rsidRDefault="00A17E39" w:rsidP="00A17E39"><w:pPr><w:spacing w:before="100" w:beforeAutospacing="1" w:after="100" w:afterAutospacing="1"/><w:rPr><w:rFonts w:ascii="Times New Roman" w:eastAsia="Times New Roman" w:hAnsi="Times New Roman" w:cs="Times New Roman"/><w:kern w:val="0"/><w:lang w:eastAsia="pl-PL"/><w14:ligatures w14:val="none"/></w:rPr></w:pPr><w:r w:rsidRPr="00A17E39"><w:rPr><w:rFonts w:ascii="Times New Roman" w:eastAsia="Times New Roman" w:hAnsi="Times New Roman" w:cs="Times New Roman"/><w:kern w:val="0"/><w:lang w:eastAsia="pl-PL"/><w14:ligatures w14:val="none"/></w:rPr><w:t>Dzięki współpracy z Ministerstwem Zdrowia Gambii, nasi wolontariusze mają dostęp do szpitali i przychodni, gdzie mogą zobaczyć zupełnie inne oblicze opieki zdrowotnej niż w Polsce. Pomagasz na oddziałach, wspierasz personel i uczysz się przez służbę.</w:t></w:r></w:p><w:p w14:paraId="4AFD0019" w14:textId="6D74AF6C" w:rsidR="00A17E39" w:rsidRPr="00A17E39" w:rsidRDefault="00A17E39" w:rsidP="00A17E39"><w:pPr><w:spacing w:before="100" w:beforeAutospacing="1" w:after="100" w:afterAutospacing="1"/><w:rPr><w:rFonts w:ascii="Times New Roman" w:eastAsia="Times New Roman" w:hAnsi="Times New Roman" w:cs="Times New Roman"/><w:kern w:val="0"/><w:lang w:eastAsia="pl-PL"/><w14:ligatures w14:val="none"/></w:rPr></w:pPr><w:r w:rsidRPr="00A17E39"><w:rPr><w:rFonts w:ascii="Times New Roman" w:eastAsia="Times New Roman" w:hAnsi="Times New